---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<a href="/#contact">Contact</a>
		</div>
		<div class="social-links">
			<a href="https://github.com/Aaidt" target="_blank" aria-label="GitHub">
				<svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path></svg>
			</a>
			<a href="https://www.linkedin.com/in/aadit-suryawanshi-542222316" target="_blank">LinkedIn</a>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 20;
		margin: 0;
		padding: 0 1.25rem;
		background: rgba(250, 250, 247, 0.9);
		border-bottom: 1px solid rgba(var(--black), 8%);
		backdrop-filter: blur(18px);
	}
	h2 {
		margin: 0;
		font-size: 1rem;
		letter-spacing: 0;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1120px;
		min-height: 64px;
		margin: 0 auto;
		gap: 1rem;
	}
	nav a {
		padding: 0.9rem 0.55rem;
		color: rgb(var(--black));
		border-bottom: 2px solid transparent;
		text-decoration: none;
		font-size: 0.92rem;
	}
	nav a.active {
		border-bottom-color: var(--accent);
	}
	.internal-links,
	.social-links,
	.social-links a {
		display: flex;
		align-items: center;
	}
	.internal-links {
		gap: 0.25rem;
	}
	.social-links {
		gap: 0.45rem;
	}
	.social-links a:hover,
	.internal-links a:hover {
		color: var(--accent);
	}
	@media (max-width: 720px) {
		header {
			padding: 0 0.8rem;
		}
		nav {
			min-height: 58px;
		}
		h2 {
			font-size: 0.9rem;
		}
		nav a {
			font-size: 0.84rem;
			padding: 0.8rem 0.35rem;
		}
		.social-links {
			display: none;
		}
	}
</style>
