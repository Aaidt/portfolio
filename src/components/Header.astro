---
import { SOCIAL_LINKS } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav aria-label="Main navigation">
		<div class="internal-links">
			<HeaderLink href={import.meta.env.BASE_URL}>Home</HeaderLink>
			<!-- <HeaderLink href={`${import.meta.env.BASE_URL}about`}>About</HeaderLink> -->
			<HeaderLink href={`${import.meta.env.BASE_URL}blog`}>Blog</HeaderLink>
		</div>

		<span class="divider" aria-hidden="true"></span>

		<div class="social-links">
			{
				SOCIAL_LINKS.map(({ label, href, icon }) => (
					<a href={href} target="_blank" rel="noopener noreferrer" aria-label={label}>
						{icon === 'github' && (
							<svg viewBox="0 0 16 16" aria-hidden="true" width="18" height="18">
								<path
									fill="currentColor"
									d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
								/>
							</svg>
						)}
						{icon === 'linkedin' && (
							<svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
								<path
									fill="currentColor"
									d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
								/>
							</svg>
						)}
						{icon === 'huggingface' && (
							<span class="emoji-icon" aria-hidden="true">🤗</span>
						)}
						{icon === 'twitter' && (
							<svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
								<path
									fill="currentColor"
									d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
								/>
							</svg>
						)}
					</a>
				))
			}
		</div>

		<span class="divider" aria-hidden="true"></span>

		<button type="button" class="theme-toggle" aria-label="Switch to dark theme" data-theme="light">
			<svg class="icon-light" viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
				<path
					fill="currentColor"
					d="M12 3.75a.75.75 0 0 1 .75.75v1.5a.75.75 0 0 1-1.5 0V4.5A.75.75 0 0 1 12 3.75Zm0 14.25a.75.75 0 0 1 .75.75v1.5a.75.75 0 0 1-1.5 0v-1.5A.75.75 0 0 1 12 18Zm8.25-6.75a.75.75 0 0 1 .75.75.75.75 0 0 1-.75.75h-1.5a.75.75 0 0 1 0-1.5h1.5Zm-14.25 0a.75.75 0 0 1 .75.75.75.75 0 0 1-.75.75h-1.5a.75.75 0 0 1 0-1.5h1.5Zm10.6-4.6a.75.75 0 0 1 1.06 0l1.06 1.06a.75.75 0 1 1-1.06 1.06l-1.06-1.06a.75.75 0 0 1 0-1.06Zm-9.7 9.7a.75.75 0 0 1 1.06 0l1.06 1.06a.75.75 0 1 1-1.06 1.06l-1.06-1.06a.75.75 0 0 1 0-1.06Zm0-9.7a.75.75 0 0 1 0 1.06l-1.06 1.06a.75.75 0 0 1-1.06-1.06l1.06-1.06a.75.75 0 0 1 1.06 0Zm9.7 9.7a.75.75 0 0 1 0 1.06l-1.06 1.06a.75.75 0 0 1-1.06-1.06l1.06-1.06a.75.75 0 0 1 1.06 0ZM12 7.5a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9Z"
				/>
			</svg>
			<svg class="icon-dark" viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
				<path
					fill="currentColor"
					d="M20.25 14.88A8.25 8.25 0 0 1 9.12 3.75a.75.75 0 0 0-.95-1.02A9.75 9.75 0 1 0 21.27 15.83a.75.75 0 0 0-1.02-.95Z"
				/>
			</svg>
		</button>
	</nav>
</header>

<script>
	const STORAGE_KEY = 'theme';
	const CYCLE = ['light', 'dark'] as const;
	type Theme = (typeof CYCLE)[number];

	function getPreferredTheme(): Theme {
		try {
			const stored = localStorage.getItem(STORAGE_KEY);
			if (stored === 'light' || stored === 'dark') {
				return stored;
			}
		} catch {}

		return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
	}

	function applyTheme(theme: Theme) {
		const root = document.documentElement;
		root.setAttribute('data-theme', theme);
		root.style.colorScheme = theme;
		try {
			localStorage.setItem(STORAGE_KEY, theme);
		} catch {}
	}

	function updateToggle(btn: HTMLButtonElement, theme: Theme) {
		btn.dataset.theme = theme;
		btn.setAttribute('aria-label', theme === 'dark' ? 'Switch to light theme' : 'Switch to dark theme');
		btn.setAttribute('aria-pressed', String(theme === 'dark'));
	}

	function initThemeToggle() {
		const btn = document.querySelector<HTMLButtonElement>('.theme-toggle');
		if (!btn || btn.dataset.initialized === 'true') return;

		btn.dataset.initialized = 'true';
		const theme = getPreferredTheme();
		applyTheme(theme);
		updateToggle(btn, theme);

		btn.addEventListener('click', () => {
			const current = (btn.dataset.theme as Theme) ?? 'light';
			const next = current === 'light' ? 'dark' : 'light';
			applyTheme(next);
			updateToggle(btn, next);
		});
	}

	initThemeToggle();
	document.addEventListener('astro:page-load', initThemeToggle);
	document.addEventListener('astro:after-swap', initThemeToggle);
</script>

<style>
	header {
		position: fixed;
		bottom: 1rem;
		left: 50%;
		transform: translateX(-50%);
		z-index: 50;
		width: auto;
		max-width: calc(100% - 1.5rem);
		padding: 0;
		pointer-events: none;
	}
	nav {
		display: flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.45rem 0.65rem;
		border-radius: 9999px;
		background: var(--dock-bg);
		border: 1px solid var(--line);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
		pointer-events: auto;
	}
	.internal-links,
	.social-links {
		display: flex;
		align-items: center;
		gap: 0.1rem;
	}
	nav a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.4rem 0.55rem;
		color: rgb(var(--black));
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.18em;
		font-size: 0.82rem;
		border-radius: 9999px;
		transition: color 0.15s, background 0.15s;
	}
	nav a:hover,
	nav a.active {
		color: var(--accent);
		background: var(--surface);
	}
	.social-links a {
		padding: 0.45rem;
	}
	.social-links a:has(.emoji-icon) {
		text-decoration: none;
	}
	.emoji-icon {
		display: inline-flex;
		align-items: center;
		font-size: 1rem;
		line-height: 0.9;
		transform: translateY(2px);
	}
	.divider {
		width: 1px;
		height: 1.25rem;
		background: var(--line);
		flex-shrink: 0;
	}
	.theme-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.45rem;
		border: none;
		border-radius: 9999px;
		background: transparent;
		color: rgb(var(--black));
		cursor: pointer;
		transition: color 0.15s, background 0.15s;
	}
	.theme-toggle:hover {
		color: var(--accent);
		background: var(--surface);
	}
	.theme-toggle svg {
		display: none;
	}
	.theme-toggle[data-theme='light'] .icon-light,
	.theme-toggle[data-theme='dark'] .icon-dark {
		display: block;
	}
	@media (max-width: 640px) {
		nav {
			gap: 0.2rem;
			padding: 0.4rem 0.5rem;
		}
		.internal-links a {
			font-size: 0.75rem;
			padding: 0.35rem 0.4rem;
		}
		.divider:first-of-type {
			display: none;
		}
	}
</style>
