---
import { SOCIAL_LINKS } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav aria-label="Main navigation">
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<a href="/#contact">Contact</a>
		</div>

		<span class="divider" aria-hidden="true"></span>

		<div class="social-links">
			{
				SOCIAL_LINKS.map(({ label, href, icon }) => (
					<a href={href} target="_blank" rel="noopener noreferrer" aria-label={label}>
						{icon === 'github' && (
							<svg viewBox="0 0 16 16" aria-hidden="true" width="18" height="18">
								<path
									fill="currentColor"
									d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
								/>
							</svg>
						)}
						{icon === 'linkedin' && (
							<svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
								<path
									fill="currentColor"
									d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
								/>
							</svg>
						)}
						{icon === 'huggingface' && (
							<svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
								<path
									fill="currentColor"
									d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm0 2.571a1.714 1.714 0 1 0-.001 3.428A1.714 1.714 0 0 0 12 2.571zm-6.857 7.2a1.714 1.714 0 1 0 0 3.428 1.714 1.714 0 0 0 0-3.429zm13.714 0a1.714 1.714 0 1 0 0 3.428 1.714 1.714 0 0 0 0-3.429zM6.17 16.457c1.2 1.714 3.086 2.829 5.83 2.829s4.63-1.115 5.83-2.829a.571.571 0 0 1 .886-.657c.243.171.514.514.343.757-1.457 2.057-3.857 3.429-6.716 3.429s-5.26-1.372-6.716-3.429a.571.571 0 0 1 .757-.886.571.571 0 0 1 .129.657z"
								/>
							</svg>
						)}
						{icon === 'twitter' && (
							<svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
								<path
									fill="currentColor"
									d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
								/>
							</svg>
						)}
					</a>
				))
			}
		</div>

		<span class="divider" aria-hidden="true"></span>

		<button type="button" class="theme-toggle" aria-label="Theme: system" data-theme="system">
			<svg class="icon-system" viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
				<path
					fill="currentColor"
					d="M12 2a1 1 0 0 1 1 1v1.07a7.002 7.002 0 0 1 5.93 5.93H20a1 1 0 1 1 0 2h-1.07A7.002 7.002 0 0 1 13 17.93V19a1 1 0 1 1-2 0v-1.07A7.002 7.002 0 0 1 5.07 11H4a1 1 0 0 1 0-2h1.07A7.002 7.002 0 0 1 11 4.07V3a1 1 0 0 1 1-1zm0 4a5 5 0 1 0 0 10 5 5 0 0 0 0-10z"
				/>
			</svg>
			<svg class="icon-light" viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
				<path
					fill="currentColor"
					d="M12 18a1 1 0 0 1 0 2H8a1 1 0 1 1 0-2h4zm6-6a1 1 0 0 1-1 1h-2a1 1 0 1 1 0-2h2a1 1 0 0 1 1 1zM7 12a1 1 0 0 1-1 1H4a1 1 0 1 1 0-2h2a1 1 0 0 1 1 1zm10.71-5.71a1 1 0 0 1 0 1.41l-1.42 1.42a1 1 0 1 1-1.41-1.41l1.41-1.42a1 1 0 0 1 1.42 0zM8.12 8.12a1 1 0 0 1 1.41 0l1.42 1.41a1 1 0 1 1-1.41 1.42L8.12 9.53a1 1 0 0 1 0-1.41zM12 6a1 1 0 0 1 1 1v2a1 1 0 1 1-2 0V7a1 1 0 0 1 1-1zm0 8a1 1 0 0 1 1 1v2a1 1 0 1 1-2 0v-2a1 1 0 0 1 1-1zM5.64 16.36a1 1 0 0 1 1.41 0l1.42 1.41a1 1 0 1 1-1.41 1.42l-1.42-1.41a1 1 0 0 1 0-1.42zm12.02-12.02a1 1 0 0 1 1.41 0l1.42 1.42a1 1 0 1 1-1.41 1.41l-1.42-1.42a1 1 0 0 1 0-1.41zM12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8z"
				/>
			</svg>
			<svg class="icon-dark" viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
				<path
					fill="currentColor"
					d="M21 14.5A7.5 7.5 0 0 1 9.5 3 6.5 6.5 0 1 0 21 14.5z"
				/>
			</svg>
		</button>
	</nav>
</header>

<script>
	const STORAGE_KEY = 'theme';
	const CYCLE = ['system', 'light', 'dark'] as const;
	type Theme = (typeof CYCLE)[number];

	function applyTheme(theme: Theme) {
		const root = document.documentElement;
		if (theme === 'system') {
			root.removeAttribute('data-theme');
		} else {
			root.setAttribute('data-theme', theme);
		}
		localStorage.setItem(STORAGE_KEY, theme);
	}

	function updateToggle(btn: HTMLButtonElement, theme: Theme) {
		btn.dataset.theme = theme;
		const labels: Record<Theme, string> = {
			system: 'Theme: system',
			light: 'Theme: light',
			dark: 'Theme: dark',
		};
		btn.setAttribute('aria-label', labels[theme]);
	}

	function initThemeToggle() {
		const btn = document.querySelector<HTMLButtonElement>('.theme-toggle');
		if (!btn) return;

		const stored = (localStorage.getItem(STORAGE_KEY) as Theme | null) ?? 'system';
		const theme = CYCLE.includes(stored) ? stored : 'system';
		updateToggle(btn, theme);

		btn.addEventListener('click', () => {
			const current = (btn.dataset.theme as Theme) ?? 'system';
			const next = CYCLE[(CYCLE.indexOf(current) + 1) % CYCLE.length];
			applyTheme(next);
			updateToggle(btn, next);
		});
	}

	initThemeToggle();
	document.addEventListener('astro:page-load', initThemeToggle);
</script>

<style>
	header {
		position: fixed;
		bottom: 1rem;
		left: 50%;
		transform: translateX(-50%);
		z-index: 50;
		width: auto;
		max-width: calc(100% - 1.5rem);
		padding: 0;
		pointer-events: none;
	}
	nav {
		display: flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.45rem 0.65rem;
		border-radius: 9999px;
		background: var(--dock-bg);
		border: 1px solid var(--line);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
		pointer-events: auto;
	}
	.internal-links,
	.social-links {
		display: flex;
		align-items: center;
		gap: 0.1rem;
	}
	nav a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.4rem 0.55rem;
		color: rgb(var(--black));
		text-decoration: none;
		font-size: 0.82rem;
		border-radius: 9999px;
		transition: color 0.15s, background 0.15s;
	}
	nav a:hover,
	nav a.active {
		color: var(--accent);
		background: var(--surface);
	}
	.social-links a {
		padding: 0.45rem;
	}
	.divider {
		width: 1px;
		height: 1.25rem;
		background: var(--line);
		flex-shrink: 0;
	}
	.theme-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.45rem;
		border: none;
		border-radius: 9999px;
		background: transparent;
		color: rgb(var(--black));
		cursor: pointer;
		transition: color 0.15s, background 0.15s;
	}
	.theme-toggle:hover {
		color: var(--accent);
		background: var(--surface);
	}
	.theme-toggle svg {
		display: none;
	}
	.theme-toggle[data-theme='system'] .icon-system,
	.theme-toggle[data-theme='light'] .icon-light,
	.theme-toggle[data-theme='dark'] .icon-dark {
		display: block;
	}
	@media (max-width: 640px) {
		nav {
			gap: 0.2rem;
			padding: 0.4rem 0.5rem;
		}
		.internal-links a {
			font-size: 0.75rem;
			padding: 0.35rem 0.4rem;
		}
		.divider:first-of-type {
			display: none;
		}
	}
</style>
