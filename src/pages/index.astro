---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import HeroImage from '../assets/blog-placeholder-4.jpg';

const projects = (await getCollection('projects')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const rabbitHoles = [
	'Training GPT-style language models from scratch in PyTorch',
	'Reinforcement learning environments',
	'Fine-tuning open-source LLMs for medical QA',
];

const reads = [
	{
		title: 'GLM-5.2: Built for Long-Horizon Tasks',
		href: 'https://z.ai/blog/glm-5.2',
	},
	{
		title: 'Contextual Retrieval by Anthropic',
		href: 'https://www.anthropic.com/engineering/contextual-retrieval',
	},
	{
		title: 'Language Models are Unsupervised Multitask Learners',
		href: 'https://cdn.openai.com/better-language-models/language_models_are_unsupervised_multitask_learners.pdf',
	},
];

---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<main>
			<section class="hero" style={`--hero-image: url(${HeroImage.src})`}>
				<div class="container hero-grid">
					<div class="hero-copy">
						<p class="kicker">Language models, systems, experiments</p>
						<h1>Aadit Suryawanshi</h1>
						<p class="lede">
							I am currently focused on understanding and building large language models from first principles.
							I spend much of my time experimenting with training pipelines, fine-tuning strategies, evaluation
							methods, and model architectures so I can understand their trade-offs directly.
						</p>
					</div>
				</div>
			</section>

			<section class="about-band">
				<div class="container two-column">
					<div>
						<p class="kicker">About me</p>
						<h2>I like understanding systems underneath the abstractions.</h2>
					</div>
					<div class="prose">
						<p>
							Over the past year I have spent most of my time building web applications, experimenting with
							language models, reading research papers, and implementing ML architectures from scratch.
						</p>
						<p>
							I prefer learning by building rather than following tutorials. Most of my projects start with a
							question I am curious about and end up becoming something larger.
						</p>
					</div>
				</div>
			</section>

			<section>
				<div class="container lists-grid">
					<div>
						<p class="kicker">Current rabbit holes</p>
						<ol class="clean-list numbered">
							{rabbitHoles.map((item) => <li>{item}</li>)}
						</ol>
					</div>
					<div>
						<p class="kicker">Recent reads</p>
						<ol class="clean-list numbered">
							{reads.map((item) => (
								<li>
									<a href={item.href} target="_blank" rel="noopener noreferrer">
										{item.title}
									</a>
								</li>
							))}
						</ol>
					</div>
				</div>
			</section>

			<section>
				<div class="container">
					<p class="kicker">Projects</p>
					<div class="projects-grid">
						{projects.map((project) => (
							<a class="project-card" href={`${import.meta.env.BASE_URL}projects/${project.id}/`}>
								{project.data.heroImage && <img src={project.data.heroImage.src} alt="" loading="lazy" />}
								<div>
									<h3>{project.data.title}</h3>
									<p>{project.data.description}</p>
								</div>
							</a>
						))}
					</div>
				</div>
			</section>

			<section class="project-band">
				<div class="container project-card featured-card">
					<p class="kicker">Featured article</p>
					<h2>Building a 25M parameter GPT from scratch</h2>
					<p>
						A practical write-up on architecture choices, data mixtures, tokenizers, training issues, and what I
						learned after training LiteGPT on FineWeb and TinyStories.
					</p>
					<a class="button" href={`${import.meta.env.BASE_URL}blog/litegpt-25m/`}>Read article</a>
				</div>
			</section>
		</main>
		<!-- <Footer /> -->
		<Header />
	</body>
</html>

<style>
	.hero {
		min-height: 100dvh;
		display: flex;
		align-items: center;
		background:
			linear-gradient(
				120deg,
				color-mix(in srgb, var(--paper) 82%, transparent) 0%,
				color-mix(in srgb, var(--paper-deep) 94%, transparent) 100%
			),
			var(--hero-image);
		background-size: cover;
		background-position: center;
		padding-bottom: 2rem;
	}
	.hero-grid,
	.two-column {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
	}
	.hero-copy {
		max-width: none;
	}
	.lede {
		max-width: none;
		color: rgb(var(--gray-dark));
		font-size: clamp(1.05rem, 2vw, 1.35rem);
	}
	.about-band,
	.project-band {
		background: transparent;
	}
	.lists-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
	}
	.clean-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 0.8rem;
	}
	.clean-list li {
		padding: 0.2rem 0;
		border: none;
		background: transparent;
	}
	.clean-list a {
		color: rgb(var(--gray-dark));
		text-decoration: none;
	}
	.clean-list a:hover {
		color: var(--accent);
		text-decoration: underline;
	}
	.numbered {
		counter-reset: item;
	}
	.numbered li {
		counter-increment: item;
	}
	.numbered li::before {
		content: counter(item, decimal-leading-zero) ' / ';
		color: var(--accent);
		font-weight: 700;
	}
	.projects-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		align-items: start;
	}
	.project-card {
		display: grid;
		gap: 0.8rem;
		min-height: 100%;
		border: 1px solid var(--line);
		border-radius: 12px;
		padding: 1rem;
		background: var(--surface);
		color: rgb(var(--gray-dark));
		text-decoration: none;
		cursor: pointer;
	}
	.project-card img {
		width: 100%;
		aspect-ratio: 16 / 10;
		object-fit: cover;
		border-radius: 8px;
	}
	.project-card h3 {
		margin-bottom: 0.25rem;
	}
	.project-card p {
		max-width: none;
		margin: 0;
	}
	.featured-card {
		display: grid;
		gap: 0.75rem;
		max-width: 620px;
	}
	@media (max-width: 760px) {
		.projects-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
