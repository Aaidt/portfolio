---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import HeroImage from '../assets/blog-placeholder-4.jpg';

const rabbitHoles = [
	'Training GPT-style language models from scratch in PyTorch',
	'Reinforcement learning environments',
	'Efficient Transformer architectures',
	'Fine-tuning open-source LLMs for medical QA',
];

const reads = [
	'GLM-5.2: Built for Long-Horizon Tasks',
	'Contextual Retrieval by Anthropic',
	'Detecting and preventing distillation attacks',
	'Language Models are Unsupervised Multitask Learners',
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero" style={`--hero-image: url(${HeroImage.src})`}>
				<div class="container hero-grid">
					<div class="hero-copy">
						<p class="kicker">Language models, systems, experiments</p>
						<h1>Aadit Suryawanshi</h1>
						<p class="lede">
							I am currently focused on understanding and building large language models from first principles.
							I spend much of my time experimenting with training pipelines, fine-tuning strategies, evaluation
							methods, and model architectures so I can understand their trade-offs directly.
						</p>
						<div class="button-row">
							<a class="button" href="/blog/">Read the blog</a>
							<a class="button secondary" href="https://github.com/Aaidt" target="_blank">GitHub</a>
						</div>
					</div>
					<div class="lab-panel" aria-label="Current research dashboard">
						<div class="panel-topline"><span></span><span></span><span></span></div>
						<div class="metric"><span>current build</span><strong>LiteGPT</strong></div>
						<div class="metric-grid">
							<div><span>params</span><strong>25M</strong></div>
							<div><span>tokens</span><strong>500M</strong></div>
							<div><span>stack</span><strong>PyTorch</strong></div>
							<div><span>focus</span><strong>LLMs</strong></div>
						</div>
						<pre><code>train.py --rope --gqa --swiglu --rmsnorm</code></pre>
					</div>
				</div>
			</section>

			<section class="about-band">
				<div class="container two-column">
					<div>
						<p class="kicker">About me</p>
						<h2>I like understanding systems underneath the abstractions.</h2>
					</div>
					<div class="prose">
						<p>
							Over the past year I have spent most of my time building web applications, experimenting with
							language models, reading research papers, and implementing ML architectures from scratch.
						</p>
						<p>
							I prefer learning by building rather than following tutorials. Most of my projects start with a
							question I am curious about and end up becoming something larger.
						</p>
					</div>
				</div>
			</section>

			<section>
				<div class="container lists-grid">
					<div>
						<p class="kicker">Current rabbit holes</p>
						<ul class="clean-list">
							{rabbitHoles.map((item) => <li>{item}</li>)}
						</ul>
					</div>
					<div>
						<p class="kicker">Recent reads</p>
						<ol class="clean-list numbered">
							{reads.map((item) => <li>{item}</li>)}
						</ol>
					</div>
				</div>
			</section>

			<section class="project-band">
				<div class="container project-card">
					<div>
						<p class="kicker">Featured article</p>
						<h2>Building a 25M parameter GPT from scratch</h2>
						<p>
							A practical write-up on architecture choices, data mixtures, tokenizers, training issues, and what
							I learned after training LiteGPT on FineWeb and TinyStories.
						</p>
					</div>
					<div class="button-row">
						<a class="button" href="/blog/litegpt-25m/">Read article</a>
						<a class="button secondary" href="https://huggingface.co/Aadit-032/LiteGPT-25M" target="_blank">Model weights</a>
					</div>
				</div>
			</section>

			<section id="contact">
				<div class="container contact-grid">
					<div>
						<p class="kicker">Contact</p>
						<h2>Send me notes, ideas, or weird model failures.</h2>
						<p>I also enjoy sci-fi, history, CrossFit, and MMA outside tech.</p>
					</div>
					<div class="contact-links">
						<a href="mailto:codexbuild.dev@gmail.com">codexbuild.dev@gmail.com</a>
						<a href="https://github.com/Aaidt" target="_blank">github.com/Aaidt</a>
						<a href="https://www.linkedin.com/in/aadit-suryawanshi-542222316" target="_blank">LinkedIn</a>
						<a href="https://huggingface.co/Aadit-032" target="_blank">Hugging Face</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		min-height: calc(100vh - 64px);
		display: flex;
		align-items: center;
		background:
			linear-gradient(120deg, rgba(250, 248, 241, 0.88), rgba(239, 234, 219, 0.74)),
			var(--hero-image);
		background-size: cover;
		background-position: center;
		padding-bottom: 4rem;
	}
	.hero-grid,
	.two-column,
	.contact-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.12fr) minmax(320px, 0.88fr);
		gap: 3rem;
		align-items: center;
	}
	.hero-copy {
		max-width: 780px;
	}
	.lede {
		max-width: 720px;
		color: rgb(var(--gray-dark));
		font-size: clamp(1.05rem, 2vw, 1.35rem);
	}
	.lab-panel {
		padding: 1rem;
		border: 1px solid rgba(24, 25, 20, 0.14);
		border-radius: 8px;
		background: rgba(21, 22, 17, 0.92);
		box-shadow: var(--box-shadow);
		color: #faf8f1;
	}
	.panel-topline {
		display: flex;
		gap: 0.35rem;
		margin-bottom: 1.5rem;
	}
	.panel-topline span {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: #f5b84b;
	}
	.panel-topline span:nth-child(2) {
		background: #7bb982;
	}
	.panel-topline span:nth-child(3) {
		background: #d86b53;
	}
	.metric span,
	.metric-grid span {
		display: block;
		color: rgba(250, 248, 241, 0.58);
		font-size: 0.72rem;
		text-transform: uppercase;
	}
	.metric strong {
		display: block;
		font-size: 2.8rem;
		line-height: 1;
	}
	.metric-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 0.75rem;
		margin: 1.2rem 0;
	}
	.metric-grid div {
		padding: 0.9rem;
		border: 1px solid rgba(250, 248, 241, 0.12);
		border-radius: 8px;
		background: rgba(250, 248, 241, 0.05);
	}
	.metric-grid strong {
		color: #fffdf6;
		font-size: 1.15rem;
	}
	.lab-panel pre {
		margin: 0;
		font-size: 0.85rem;
	}
	.about-band,
	.project-band {
		background: var(--paper-deep);
	}
	.lists-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}
	.clean-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 0.8rem;
	}
	.clean-list li {
		padding: 1rem;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.38);
	}
	.numbered {
		counter-reset: item;
	}
	.numbered li {
		counter-increment: item;
	}
	.numbered li::before {
		content: counter(item, decimal-leading-zero) ' / ';
		color: var(--accent);
		font-weight: 700;
	}
	.project-card {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 2rem;
		align-items: end;
	}
	.project-card p {
		max-width: 760px;
	}
	.contact-links {
		display: grid;
		gap: 0.75rem;
	}
	.contact-links a {
		padding: 1rem;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.44);
		text-decoration: none;
	}
	@media (max-width: 820px) {
		.hero {
			min-height: auto;
		}
		.hero-grid,
		.two-column,
		.contact-grid,
		.lists-grid,
		.project-card {
			grid-template-columns: 1fr;
		}
	}
</style>
